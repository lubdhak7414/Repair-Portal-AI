# ============================================
# Repair Portal — Environment Configuration
# ============================================
# Copy this file to .env and fill in values.
#   cp .env.example .env
# ============================================

# ---- Server ----
PORT=3000

# ---- Authentication ----
# Generate a random secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-random-64-char-hex-string

# ---- AI Diagnosis ----
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# ---- Database (optional) ----
# SQLite database path relative to backend/
# Defaults to: backend/data/repair-portal.db
# DB_PATH=./backend/data/repair-portal.db

# ---- CORS (optional) ----
# Frontend origin for CORS headers
# Defaults to: http://localhost:5173
# CORS_ORIGIN=http://localhost:5173

# ---- Platform Fee (optional) ----
# Percentage charged as platform fee on each payment
# Defaults to: 5 (percent)
# PLATFORM_FEE_PERCENT=5
